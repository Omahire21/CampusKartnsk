# ─── CampusKart Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.

# Flask
SECRET_KEY=your_very_strong_random_secret_key_here
FLASK_ENV=development

# ── Firebase (Option A: Local JSON file — recommended for development) ────────
# Download your Firebase Service Account JSON from:
# Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_CREDENTIALS_PATH=./serviceAccountKey.json

# ── Firebase (Option B: Individual env vars — recommended for Vercel/production)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_PRIVATE_KEY_ID=your-key-id
# FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_CLIENT_ID=123456789

# Firebase Storage bucket (optional, needed for image uploads to cloud)
# FIREBASE_STORAGE_BUCKET=your-project.appspot.com
